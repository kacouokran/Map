    {
      "cell_type": "code",
      "source": [
        "library(\"vcfR\")\n",
        "\n",
        "library(\"rrBLUP\")\n",
        "#See help of rrBLUP package:\n",
        "?rrBLUP\n",
        "\n",
        "# Importing the molecular data (VCF format): -----------------\n",
        "vcfR.object <- read.vcfR(\"output_rubber_Brazil_LIR122_Feb20_JM.vcf.gz\")\n",
        "vcfR.object@gt[1:8,1:2]\n",
        "\n",
        "\n",
        "# ......extract genotype matrix GT: ------------\n",
        "GT1=extract.gt(x = vcfR.object, element = \"GT\")\n",
        "GT1[1:5,1:5]\n",
        "dim(GT1) #number of SNPs x number of individuals\n",
        "\n",
        "# ......recode GT matrix into -1,0,1 (required for rrBLUP - see help):  -----------\n",
        "GT1[GT1==\"0/1\"]= 0\n",
        "GT1[GT1==\"1/0\"]= 0\n",
        "GT1[GT1==\"1/1\"]= 1\n",
        "GT1[GT1==\"0/0\"]= -1\n",
        "class(GT1)= \"numeric\"\n",
        "GT <- t(GT1)\n",
        "GT[1:10,1:5]\n",
        "\n",
        "\n",
        "\n",
        "# Import file of phenotypic data per clone:------------------\n",
        "#csv data:\n",
        "BrazilPheno_csv =  read.csv(\"adjusted_DAP_BRAZIL_lw_Nov2019_Age6.5.csv\", stringsAsFactors=FALSE)\n",
        "nrow(BrazilPheno_csv)\n",
        "\n",
        "#or, xlsx data (same), in case it does not work with csv data:\n",
        "#library(readxl)\n",
        "#BrazilPheno_csv =  read_excel(\"adjusted_DAP_BRAZIL_lw_Nov2019_Age6.5.xlsx\")\n",
        "\n",
        "\n",
        "# .......keep only clones common to the 2 files:---------\n",
        "BrazilPheno_csv=BrazilPheno_csv[BrazilPheno_csv$gid%in%rownames(GT),]\n",
        "nrow(BrazilPheno_csv)\n",
        "GT=GT[rownames(GT)%in%BrazilPheno_csv$gid,]\n",
        "dim(GT)\n",
        "\n",
        "# Define training and validation set: ----------------\n",
        "training_size=225 #number of individuals we want to have for training\n",
        "                  #the remaining ones will be used for validation (ie to compute the prediction accuracy of GS)\n",
        "BrazilPheno_csv$Set=\"validation\"\n",
        "BrazilPheno_csv$Set[sample(x = 1:nrow(BrazilPheno_csv) , size = training_size, replace = F) ]=\"training\"\n",
        "#c(rep(\"training\", times=training_size), rep(\"validation\",times=nrow(BrazilPheno_csv)-training_size))\n",
        "\n",
        "\n",
        "head(BrazilPheno_csv)\n",
        "tail(BrazilPheno_csv)\n",
        "table(BrazilPheno_csv$Set)\n",
        "\n",
        "# Number of SNPs we want to use: -------------------\n",
        "nS=25\n",
        "cat(nS, '\\n')\n",
        "\n",
        "# Keep the number of SNPs in the GT matrix: -----------------\n",
        "GT_impX<-GT[,round(seq(from = 1, to = ncol(GT),length.out = nS))]\n",
        "dim(GT_impX)\n",
        "\n",
        "# Extract phenotypic data for training and validation: ---------\n",
        "trainData <- BrazilPheno_csv[BrazilPheno_csv$Set==\"training\" , ]\n",
        "dim(trainData)\n",
        "\n",
        "testData <- BrazilPheno_csv[ BrazilPheno_csv$Set==\"validation\" , ]\n",
        "dim(testData)\n",
        "\n",
        "\n",
        "# Extract SNP data for training and validation: ---------\n",
        "GT_S1=GT_impX[rownames(GT_impX)%in%trainData$gid,]\n",
        "dim(GT_S1)\n",
