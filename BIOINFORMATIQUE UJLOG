        "dim(GT_S2)\n",
        "\n",
        "\n",
        "#Put clones in the same order in SNP and phenotypic data:\n",
        "GT_S1=GT_S1[as.character(trainData$gid),]\n",
        "identical(rownames(GT_S1), as.character(trainData$gid)) #check if order it the same\n",
        "\n",
        "GT_S2=GT_S2[as.character(testData$gid),]\n",
        "identical(rownames(GT_S2), as.character(testData$gid)) #check if order it the same\n",
