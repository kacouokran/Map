        "        fill     = type),\n",
        "    color        = \"white\",\n",
        "    size         = 3.2,\n",
        "    fontface     = \"bold\",\n",
        "    box.padding  = 0.8,\n",
        "    point.padding = 0.5,\n",
        "    label.size   = 0.3,\n",
        "    alpha        = 0.92,\n",
        "    min.segment.length = 0.3,\n",
        "    show.legend  = FALSE\n",
        "  ) +\n",
        "\n",
        "  # ── ÉCHELLES ET NORD ──\n",
        "  annotation_scale(location   = \"br\",\n",
        "                   width_hint = 0.25,\n",
