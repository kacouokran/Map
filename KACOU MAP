        "library(sf)\n",
        "library(ggplot2)\n",
        "library(ggspatial)\n",
        "library(rnaturalearth)\n",
        "library(rnaturalearthdata)\n",
        "library(dplyr)\n",
        "library(ggrepel)\n",
        "library(cowplot)\n",
        "library(RColorBrewer)\n",
        "library(scales)\n",
        "\n",
        "# ── 1. COORDONNÉES DES SITES D'ÉTUDE ─────────────────────────────────────────\n",
        "\n",
        "sites <- data.frame(\n",
        "  nom        = c(\"Daloa\", \"Zoukougbeu\", \"Gonaté\"),\n",
        "  type       = c(\"Urbain\", \"Semi-urbain\", \"Rural\"),\n",
        "  longitude  = c(-6.4500, -6.9000, -6.6500),\n",
        "  latitude   = c(6.8833,   6.9500,   6.6500),\n",
        "  population = c(350000,    60000,     5000),\n",
        "  stringsAsFactors = FALSE\n",
        ")\n",
        "\n",
        "sites_sf <- st_as_sf(sites,\n",
        "                     coords = c(\"longitude\", \"latitude\"),\n",
        "                     crs    = 4326)   # WGS84\n",
        "\n",
        "cat(\"Sites d'étude chargés:\\n\")\n",
        "print(sites[, c(\"nom\", \"type\", \"longitude\", \"latitude\")])\n",
        "\n",
        "# ── 2. DONNÉES GÉOGRAPHIQUES ──────────────────────────────────────────────────\n",
        "\n",
        "# Continent africain\n",
        "afrique <- ne_countries(continent = \"Africa\",\n",
        "                        scale      = \"medium\",\n",
        "                        returnclass = \"sf\")\n",
        "\n",
        "# Tous les pays du monde (pour le contexte global)\n",
        "monde <- ne_countries(scale = \"small\", returnclass = \"sf\")\n",
        "\n",
        "# Côte d'Ivoire uniquement\n",
        "cote_ivoire <- ne_countries(country = \"Ivory Coast\",\n",
        "                            scale   = \"large\",\n",
        "                            returnclass = \"sf\")\n",
        "\n",
        "# Pays voisins (contexte régional)\n",
        "voisins <- ne_countries(\n",
        "  country = c(\"Ghana\", \"Liberia\", \"Guinea\", \"Mali\",\n",
        "              \"Burkina Faso\", \"Guinea-Bissau\", \"Senegal\"),\n",
        "  scale   = \"medium\",\n",
        "  returnclass = \"sf\"\n",
        ")\n",
        "\n",
        "# ── 3. CARTE 1 : AFRIQUE (contexte mondial) ───────────────────────────────────\n",
        "\n",
        "# Bounding box Afrique\n",
        "bbox_afrique <- c(xmin = -20, xmax = 55, ymin = -37, ymax = 38)\n",
        "\n",
        "carte_afrique <- ggplot() +\n",
        "\n",
        "  # Fond océan\n",
        "  theme(panel.background = element_rect(fill = \"#C6E3F3\")) +\n",
        "\n",
        "  # Tous les pays africains\n",
        "  geom_sf(data   = afrique,\n",
        "          fill   = \"#E8E0D0\",\n",
        "          color  = \"#AAAAAA\",\n",
        "          linewidth = 0.3) +\n",
        "\n",
        "  # Côte d'Ivoire mise en évidence\n",
        "  geom_sf(data   = cote_ivoire,\n",
        "          fill   = \"#E74C3C\",\n",
        "          color  = \"#C0392B\",\n",
        "          linewidth = 0.6) +\n",
        "\n",
        "  # Rectangle de localisation\n",
        "  annotate(\"rect\",\n",
        "           xmin = -8.6, xmax = -2.5,\n",
        "           ymin =  4.3, ymax =  10.7,\n",
        "           fill  = NA,\n",
        "           color = \"#E74C3C\",\n",
        "           linewidth = 1.2,\n",
        "           linetype = \"dashed\") +\n",
        "\n",
        "  # Étiquette CI\n",
        "  annotate(\"text\",\n",
        "           x = -5.5, y = 7.5,\n",
        "           label = \"Côte\\nd'Ivoire\",\n",
        "           size  = 3.2,\n",
        "           fontface = \"bold\",\n",
        "           color = \"white\",\n",
        "           hjust = 0.5) +\n",
        "\n",
        "  # Échelle et nord\n",
        "  annotation_scale(location = \"bl\",\n",
        "                   width_hint = 0.3,\n",
        "                   text_cex   = 0.7) +\n",
        "  annotation_north_arrow(location = \"tl\",\n",
        "                         which_north = \"true\",\n",
        "                         height = unit(0.8, \"cm\"),\n",
        "                         width  = unit(0.8, \"cm\")) +\n",
        "\n",
        "  # Emprise\n",
        "  coord_sf(xlim = c(-20, 55), ylim = c(-37, 38), expand = FALSE) +\n",
        "\n",
        "  # Thème épuré\n",
        "  theme_void() +\n",
        "  theme(\n",
        "    panel.background  = element_rect(fill = \"#C6E3F3\", color = \"black\", linewidth = 0.8),\n",
        "    panel.border      = element_rect(color = \"black\", fill = NA, linewidth = 0.8),\n",
        "    plot.title        = element_text(size = 10, face = \"bold\", hjust = 0.5,\n",
        "                                     margin = margin(b = 4))\n",
        "  ) +\n",
        "  labs(title = \"A — Localisation en Afrique\")\n",
        "\n",
        "# ── 4. CARTE 2 : CÔTE D'IVOIRE (contexte national) ───────────────────────────\n",
        "\n",
        "# Point représentant le Haut Sassandra (centroïde approximatif)\n",
        "haut_sassandra_pt <- data.frame(lon = -6.45, lat = 7.1)\n",
        "\n",
        "carte_ci <- ggplot() +\n",
        "\n",
        "  # Pays voisins\n",
        "  geom_sf(data  = voisins,\n",
        "          fill  = \"#F5F0E8\",\n",
        "          color = \"#BBBBBB\",\n",
        "          linewidth = 0.4) +\n",
        "\n",
        "  # Côte d'Ivoire\n",
        "  geom_sf(data  = cote_ivoire,\n",
        "          fill  = \"#D4E6C3\",\n",
        "          color = \"#2C7A2C\",\n",
        "          linewidth = 0.8) +\n",
        "\n",
        "  # Rectangle zone d'étude (Haut Sassandra)\n",
        "  annotate(\"rect\",\n",
        "           xmin = -7.5, xmax = -5.8,\n",
        "           ymin =  6.3, ymax =  7.7,\n",
        "           fill  = NA,\n",
        "           color = \"#E74C3C\",\n",
        "           linewidth = 1.2) +\n",
        "\n",
        "  # Label zone d'étude\n",
        "  annotate(\"text\",\n",
        "           x = -6.65, y = 7.85,\n",
        "           label = \"Haut Sassandra\",\n",
        "           size  = 3.5,\n",
        "           fontface = \"bold.italic\",\n",
        "           color = \"#E74C3C\") +\n",
        "\n",
        "  # Capitale Abidjan (repère)\n",
        "  geom_point(data = data.frame(lon = -4.0167, lat = 5.3167),\n",
        "             aes(x = lon, y = lat),\n",
        "             shape = 18, size = 3.5, color = \"#2C3E50\") +\n",
        "  geom_text(data = data.frame(lon = -4.0167, lat = 5.3167),\n",
        "            aes(x = lon, y = lat, label = \"Abidjan\"),\n",
        "            nudge_y = 0.2, size = 3, fontface = \"italic\", color = \"#2C3E50\") +\n",
        "\n",
        "  # Yamoussoukro (capitale politique)\n",
        "  geom_point(data = data.frame(lon = -5.2767, lat = 6.8276),\n",
        "             aes(x = lon, y = lat),\n",
        "             shape = 17, size = 3.5, color = \"#2C3E50\") +\n",
        "  geom_text(data = data.frame(lon = -5.2767, lat = 6.8276),\n",
        "            aes(x = lon, y = lat, label = \"Yamoussoukro\"),\n",
        "            nudge_y = 0.2, size = 2.8, fontface = \"italic\", color = \"#2C3E50\") +\n",
        "\n",
        "  # Fleuve Sassandra (approximatif)\n",
        "  geom_segment(aes(x = -6.1, xend = -6.1, y = 4.5, yend = 7.5),\n",
        "               color = \"#5B9BD5\", linewidth = 0.8, linetype = \"solid\") +\n",
        "  annotate(\"text\", x = -5.85, y = 6.0,\n",
        "           label = \"Sassandra\", angle = 90,\n",
        "           size = 2.8, color = \"#5B9BD5\", fontface = \"italic\") +\n",
        "\n",
        "  # Échelle et nord\n",
        "  annotation_scale(location = \"bl\", width_hint = 0.3, text_cex = 0.7) +\n",
        "  annotation_north_arrow(location = \"tl\", which_north = \"true\",\n",
        "                         height = unit(0.9, \"cm\"), width = unit(0.9, \"cm\")) +\n",
        "\n",
        "  coord_sf(xlim = c(-8.7, -2.4), ylim = c(4.2, 10.8), expand = FALSE) +\n",
        "\n",
        "  theme_void() +\n",
        "  theme(\n",
        "    panel.background = element_rect(fill = \"#C6E3F3\", color = \"black\", linewidth = 0.8),\n",
        "    panel.border     = element_rect(color = \"black\", fill = NA, linewidth = 0.8),\n",
        "    plot.title       = element_text(size = 10, face = \"bold\", hjust = 0.5,\n",
        "                                    margin = margin(b = 4))\n",
        "  ) +\n",
        "  labs(title = \"B — Côte d'Ivoire\")\n",
        "\n",
        "# ── 5. CARTE 3 : ZONE D'ÉTUDE — HAUT SASSANDRA ───────────────────────────────\n",
        "\n",
        "# Couleurs par type de localité\n",
        "pal_sites <- c(\n",
        "  \"Urbain\"      = \"#E74C3C\",\n",
        "  \"Semi-urbain\" = \"#F39C12\",\n",
        "  \"Rural\"       = \"#27AE60\"\n",
        ")\n",
        "\n",
        "# Taille des points proportionnelle à la population\n",
        "sites$pop_scaled <- sqrt(sites$population) / 15\n",
        "\n",
        "carte_zone <- ggplot() +\n",
        "\n",
        "  # Fond océan / contexte\n",
        "  theme(panel.background = element_rect(fill = \"#EEF4FF\")) +\n",
        "\n",
        "  # Pays CI simplifié en fond\n",
        "  geom_sf(data  = cote_ivoire,\n",
        "          fill  = \"#F0F4E8\",\n",
        "          color = \"#5A8A5A\",\n",
        "          linewidth = 0.6) +\n",
        "\n",
        "  # Rectangle de la zone d'étude\n",
        "  annotate(\"rect\",\n",
        "           xmin = -7.5, xmax = -5.8,\n",
        "           ymin =  6.3, ymax =  7.7,\n",
        "           fill  = \"#FFF8E7\",\n",
        "           color = \"#E74C3C\",\n",
        "           linewidth = 1.0,\n",
        "           alpha = 0.3) +\n",
        "\n",
        "  # Fleuve Sassandra\n",
        "  geom_segment(aes(x = -6.1, xend = -6.1, y = 6.0, yend = 7.8),\n",
        "               color = \"#5B9BD5\", linewidth = 1.2) +\n",
        "  annotate(\"text\", x = -5.88, y = 6.9,\n",
        "           label = \"Sassandra\", angle = 90,\n",
        "           size = 3, color = \"#3B7AB5\", fontface = \"italic\") +\n",
        "\n",
        "  # Sites d'étude (cercles proportionnels)\n",
        "  geom_point(data = sites,\n",
        "             aes(x = longitude, y = latitude,\n",
        "                 color = type,\n",
        "                 size  = pop_scaled),\n",
        "             shape = 21,\n",
        "             fill  = \"white\",\n",
        "             stroke = 1.5) +\n",
        "\n",
        "  geom_point(data = sites,\n",
        "             aes(x = longitude, y = latitude,\n",
        "                 color = type,\n",
        "                 size  = pop_scaled / 3),\n",
        "             alpha = 0.7) +\n",
        "\n",
        "  # Étiquettes des sites (non chevauchantes)\n",
        "  geom_label_repel(data = sites,\n",
        "                   aes(x = longitude, y = latitude,\n",
        "                       label = paste0(nom, \"\\n(\", type, \")\"),\n",
        "                       color = type),\n",
        "                   size           = 3.5,\n",
        "                   fontface       = \"bold\",\n",
        "                   box.padding    = 0.6,\n",
        "                   point.padding  = 0.4,\n",
        "                   min.segment.length = 0.2,\n",
        "                   fill           = \"white\",\n",
        "                   alpha          = 0.9,\n",
        "                   label.size     = 0.3,\n",
        "                   show.legend    = FALSE) +\n",
        "\n",
        "  # Daloa (chef-lieu — étoile)\n",
        "  geom_point(data = sites[sites$nom == \"Daloa\", ],\n",
        "             aes(x = longitude, y = latitude),\n",
        "             shape = 8, size = 5, color = \"#E74C3C\", stroke = 1.5) +\n",
        "\n",
        "  # Annotation distances approximatives\n",
        "  annotate(\"text\", x = -7.3, y = 7.65,\n",
        "           label = \"~ 45 km entre Daloa\\net Zoukougbeu\",\n",
        "           size = 2.8, color = \"#555555\",\n",
        "           hjust = 0, fontface = \"italic\") +\n",
        "  annotate(\"text\", x = -7.3, y = 6.45,\n",
        "           label = \"~ 28 km entre Daloa\\net Gonaté\",\n",
        "           size = 2.8, color = \"#555555\",\n",
        "           hjust = 0, fontface = \"italic\") +\n",
        "\n",
        "  # Ligne reliant les sites\n",
        "  geom_segment(aes(x = -6.45, xend = -6.90, y = 6.883, yend = 6.95),\n",
        "               color = \"#AAAAAA\", linewidth = 0.6, linetype = \"dashed\") +\n",
        "  geom_segment(aes(x = -6.45, xend = -6.65, y = 6.883, yend = 6.65),\n",
        "               color = \"#AAAAAA\", linewidth = 0.6, linetype = \"dashed\") +\n",
        "\n",
        "  # Légende couleurs\n",
        "  scale_color_manual(name   = \"Type de localité\",\n",
        "                     values = pal_sites) +\n",
        "\n",
        "  # Légende taille\n",
        "  scale_size_continuous(name  = \"Population\\n(√ échelle)\",\n",
        "                        range = c(3, 10),\n",
        "                        guide = guide_legend(\n",
        "                          override.aes = list(stroke = 1.5, shape = 21,\n",
        "                                              fill = \"white\"))) +\n",
        "\n",
        "  # Graticule et étiquettes\n",
        "  scale_x_continuous(breaks = seq(-8, -5, by = 1),\n",
        "                     labels = function(x) paste0(abs(x), \"°O\")) +\n",
        "  scale_y_continuous(breaks = seq(6, 8, by = 0.5),\n",
        "                     labels = function(y) paste0(y, \"°N\")) +\n",
        "\n",
        "  # Échelle et nord\n",
        "  annotation_scale(location = \"br\", width_hint = 0.3, text_cex = 0.8) +\n",
        "  annotation_north_arrow(location = \"tr\", which_north = \"true\",\n",
        "                         height = unit(1.1, \"cm\"), width = unit(1.1, \"cm\"),\n",
        "                         style = north_arrow_fancy_orienteering(\n",
        "                           fill      = c(\"white\", \"#2C3E50\"),\n",
        "                           line_col  = \"#2C3E50\",\n",
        "                           text_col  = \"#2C3E50\")) +\n",
        "\n",
        "  coord_sf(xlim = c(-7.7, -5.6), ylim = c(6.1, 7.9), expand = FALSE) +\n",
        "\n",
        "  theme_bw(base_size = 11) +\n",
        "  theme(\n",
        "    panel.background  = element_rect(fill = \"#EEF4FF\"),\n",
        "    panel.grid.major  = element_line(color = \"#DDDDDD\", linewidth = 0.3,\n",
        "                                     linetype = \"dotted\"),\n",
        "    panel.border      = element_rect(color = \"black\", linewidth = 1),\n",
        "    legend.position   = \"right\",\n",
        "    legend.background = element_rect(fill = \"white\", color = \"#CCCCCC\",\n",
        "                                     linewidth = 0.5),\n",
        "    legend.key        = element_rect(fill = \"white\"),\n",
        "    axis.text         = element_text(size = 8),\n",
        "    axis.title        = element_blank(),\n",
        "    plot.title        = element_text(size = 11, face = \"bold\", hjust = 0.5,\n",
        "                                     margin = margin(b = 6))\n",
        "  ) +\n",
        "  labs(title = \"C — Sites d'étude dans le Haut Sassandra\")\n",
        "\n",
        "# ── 6. ASSEMBLAGE DES 3 CARTES ────────────────────────────────────────────────\n",
        "\n",
        "# Carte gauche : Afrique + CI superposés\n",
        "colonne_gauche <- plot_grid(\n",
        "  carte_afrique,\n",
        "  carte_ci,\n",
        "  ncol   = 1,\n",
        "  labels = NULL,\n",
        "  rel_heights = c(1, 1)\n",
        ")\n",
        "\n",
        "# Assemblage final\n",
        "carte_finale <- plot_grid(\n",
        "  colonne_gauche,\n",
        "  carte_zone,\n",
        "  ncol         = 2,\n",
        "  rel_widths   = c(1, 1.8),\n",
        "  align        = \"hv\"\n",
        ")\n",
        "\n",
        "# Titre général\n",
        "titre <- ggdraw() +\n",
        "  draw_label(\n",
        "    \"Localisation de la zone d'étude — Haut Sassandra, Côte d'Ivoire\",\n",
        "    fontface  = \"bold\",\n",
        "    size      = 14,\n",
        "    x         = 0.5,\n",
        "    hjust     = 0.5\n",
        "  )\n",
        "\n",
        "sous_titre <- ggdraw() +\n",
        "  draw_label(\n",
        "    \"Sites de collecte des déchets organiques ménagers : Daloa, Zoukougbeu et Gonaté\",\n",
        "    fontface = \"italic\",\n",
        "    size     = 10,\n",
        "    color    = \"#555555\",\n",
        "    x        = 0.5,\n",
        "    hjust    = 0.5\n",
        "  )\n",
        "\n",
        "note_bas <- ggdraw() +\n",
        "  draw_label(\n",
        "    \"Système de coordonnées : WGS84 (EPSG:4326)  |  Sources : Natural Earth, GADM\",\n",
        "    size  = 8,\n",
        "    color = \"#777777\",\n",
        "    x     = 0.5,\n",
        "    hjust = 0.5\n",
        "  )\n",
        "\n",
        "carte_complete <- plot_grid(\n",
        "  titre,\n",
        "  sous_titre,\n",
