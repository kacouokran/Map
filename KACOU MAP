        "\n",
        "  annotation_north_arrow(\n",
        "    location    = \"tr\",\n",
        "    which_north = \"true\",\n",
        "    pad_x       = unit(0.4, \"cm\"),\n",
        "    pad_y       = unit(0.4, \"cm\"),\n",
        "    height      = unit(1.4, \"cm\"),\n",
        "    width       = unit(1.4, \"cm\"),\n",
        "    style       = north_arrow_fancy_orienteering(\n",
        "      fill     = c(\"white\", \"#2C3E50\"),\n",
        "      line_col = \"#2C3E50\",\n",
        "      text_col = \"#2C3E50\",\n",
        "      text_size = 10\n",
        "    )\n",
        "  ) +\n",
        "\n",
        "  # ── LÉGENDES ──\n",
        "  scale_color_manual(name   = \"Type de site\",\n",
        "                     values = pal_type) +\n",
        "  scale_fill_manual(name    = \"Type de site\",\n",
        "                    values  = pal_type) +\n",
        "  scale_size_continuous(name  = \"Population\",\n",
        "                        range = c(4, 14),\n",
        "                        labels = label_number(big.mark = \" \")) +\n",
        "\n",
        "  # ── AXES ──\n",
        "  scale_x_continuous(breaks = seq(-8.5, -5.5, by = 0.5),\n",
        "                     labels = function(x) paste0(abs(x), \"°O\")) +\n",
        "  scale_y_continuous(breaks = seq(5.0, 8.5, by = 0.5),\n",
        "                     labels = function(y) paste0(y, \"°N\")) +\n",
        "\n",
        "  # ── EMPRISE ──\n",
        "  coord_sf(xlim = c(-8.0, -5.5), ylim = c(5.8, 8.2), expand = FALSE) +\n",
        "\n",
        "  # ── THÈME ──\n",
        "  theme_bw(base_size = 12) +\n",
        "  theme(\n",
        "    panel.background  = element_rect(fill = \"#D6EBF5\"),\n",
