      "cell_type": "code",
      "source": [
        "# =============================================================================\n",
        "# SCRIPT 05 — CARTE CLIMATIQUE ET PROFILS MÉTÉOROLOGIQUES\n",
        "# Haut Sassandra — Côte d'Ivoire\n",
        "# =============================================================================\n",
        "# Produit : Carte des zones climatiques + climogrammes (T° / pluie) des 3 sites\n",
        "#           + graphique de l'humidité relative mensuelle\n",
        "# Source   : SODEXAM / données climatiques publiées pour la région\n",
        "# =============================================================================\n",
        "\n",
        "library(sf)\n",
        "library(ggplot2)\n",
        "library(ggspatial)\n",
        "library(rnaturalearth)\n",
        "library(rnaturalearthdata)\n",
        "library(dplyr)\n",
        "library(tidyr)\n",
        "library(cowplot)\n",
        "library(RColorBrewer)\n",
        "library(scales)\n",
        "library(patchwork)\n",
        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "# 1. DONNÉES CLIMATIQUES MENSUELLES (SODEXAM / Moyennes 1991-2020)\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "mois <- c(\"Jan\",\"Fév\",\"Mar\",\"Avr\",\"Mai\",\"Jun\",\n",
        "          \"Jul\",\"Aoû\",\"Sep\",\"Oct\",\"Nov\",\"Déc\")\n",
        "\n",
        "# Données climatiques — Station de Daloa (station synoptique OMM 65506)\n",
        "daloa_clim <- data.frame(\n",
        "  mois       = factor(mois, levels = mois),\n",
        "  mois_num   = 1:12,\n",
        "  site       = \"Daloa\",\n",
        "  pluie_mm   = c(22,  41,  88, 131, 142, 162, 91, 72, 151, 161,  75,  30),\n",
        "  T_max      = c(34.2, 35.1, 35.3, 34.0, 32.0, 29.5, 28.0, 28.3, 30.1, 30.8, 32.5, 34.1),\n",
        "  T_min      = c(20.1, 21.3, 22.5, 22.8, 22.5, 21.4, 20.8, 20.9, 21.3, 21.8, 21.5, 20.5),\n",
        "  T_moy      = c(27.2, 28.2, 28.9, 28.4, 27.3, 25.5, 24.4, 24.6, 25.7, 26.3, 27.0, 27.3),\n",
        "  HR_pct     = c(65,   68,   75,   82,   85,   88,   88,   87,   86,   85,   78,   68)\n",
        ")\n",
        "daloa_clim$T_moy_rnd <- round(daloa_clim$T_moy, 1)\n",
        "\n",
        "# Zoukougbeu (estimé à partir interpolation régionale)\n",
        "zoukougbeu_clim <- data.frame(\n",
        "  mois       = factor(mois, levels = mois),\n",
        "  mois_num   = 1:12,\n",
        "  site       = \"Zoukougbeu\",\n",
        "  pluie_mm   = c(18,  35,  80, 120, 138, 155, 85,  68, 145, 155,  70,  25),\n",
        "  T_max      = c(34.5, 35.4, 35.6, 34.2, 32.3, 29.8, 28.2, 28.5, 30.4, 31.1, 32.8, 34.4),\n",
        "  T_min      = c(19.8, 21.0, 22.2, 22.5, 22.2, 21.1, 20.5, 20.6, 21.0, 21.5, 21.2, 20.2),\n",
        "  T_moy      = c(27.2, 28.2, 28.9, 28.4, 27.3, 25.5, 24.4, 24.6, 25.7, 26.3, 27.0, 27.3),\n",
        "  HR_pct     = c(62,   65,   72,   79,   82,   85,   86,   84,   83,   82,   75,   65)\n",
        ")\n",
        "zoukougbeu_clim$T_moy_rnd <- round(zoukougbeu_clim$T_moy, 1)\n",
        "\n",
        "# Gonaté (estimé)\n",
        "gonante_clim <- data.frame(\n",
        "  mois       = factor(mois, levels = mois),\n",
        "  mois_num   = 1:12,\n",
        "  site       = \"Gonaté\",\n",
        "  pluie_mm   = c(20,  38,  84, 126, 140, 158, 88,  70, 148, 158,  72,  28),\n",
        "  T_max      = c(34.3, 35.2, 35.4, 34.1, 32.1, 29.6, 28.1, 28.4, 30.2, 30.9, 32.6, 34.2),\n",
        "  T_min      = c(20.0, 21.2, 22.3, 22.6, 22.4, 21.3, 20.7, 20.8, 21.2, 21.6, 21.4, 20.4),\n",
        "  T_moy      = c(27.2, 28.2, 28.9, 28.4, 27.3, 25.5, 24.4, 24.6, 25.7, 26.3, 27.0, 27.3),\n",
        "  HR_pct     = c(64,   67,   74,   81,   84,   87,   87,   86,   85,   84,   77,   67)\n",
        ")\n",
        "gonante_clim$T_moy_rnd <- round(gonante_clim$T_moy, 1)\n",
        "\n",
        "# Combinaison pour graphiques comparatifs\n",
        "all_clim <- bind_rows(daloa_clim, zoukougbeu_clim, gonante_clim)\n",
        "\n",
        "pal_sites <- c(\n",
        "  \"Daloa\"      = \"#C0392B\",\n",
        "  \"Zoukougbeu\" = \"#E67E22\",\n",
        "  \"Gonaté\"     = \"#27AE60\"\n",
        ")\n",
        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "# 2. CLIMOGRAMMES (WALTER-LIETH) PAR SITE\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "make_climogramme <- function(data_site, nom_site, couleur) {\n",
        "\n",
        "  # Coefficient d'échelle Walter-Lieth : 1°C = 2 mm\n",
        "  coef <- 2\n",
        "\n",
        "  # Calcul de l'axe secondaire\n",
        "  max_T    <- max(data_site$T_moy) + 5\n",
        "  max_P    <- max(data_site$pluie_mm) + 20\n",
        "  scale_P  <- max_T / (max_P / coef)\n",
        "\n",
        "  ggplot(data_site, aes(x = mois_num)) +\n",
        "\n",
        "    # ── Zones saisons : pluies > sèches ──\n",
        "    geom_ribbon(aes(ymin = T_moy,\n",
        "                    ymax = pluie_mm / coef),\n",
        "                data = data_site %>% filter(pluie_mm / coef > T_moy),\n",
        "                fill  = \"#5B9BD5\",\n",
        "                alpha = 0.25) +\n",
        "    geom_ribbon(aes(ymin = pluie_mm / coef,\n",
        "                    ymax = T_moy),\n",
        "                data = data_site %>% filter(pluie_mm / coef <= T_moy),\n",
        "                fill  = \"#E8C97A\",\n",
        "                alpha = 0.35) +\n",
        "\n",
        "    # ── Barres de précipitations ──\n",
        "    geom_col(aes(y = pluie_mm / coef),\n",
        "             fill  = \"#2980B9\",\n",
        "             alpha = 0.5,\n",
        "             width = 0.8) +\n",
        "\n",
        "    # ── Courbe de température ──\n",
        "    geom_line(aes(y = T_moy),\n",
        "              color     = couleur,\n",
        "              linewidth = 1.6) +\n",
        "    geom_point(aes(y = T_moy),\n",
        "               color = couleur,\n",
        "               size  = 2.5,\n",
        "               shape = 21,\n",
        "               fill  = \"white\",\n",
        "               stroke = 1.5) +\n",
        "    geom_text(aes(y = T_moy + 0.8, label = T_moy_rnd %||% round(T_moy,1)),\n",
        "              size = 2.8, color = couleur, fontface = \"bold\") +\n",
        "\n",
        "    # ── Axes ──\n",
        "    scale_x_continuous(breaks = 1:12, labels = mois) +\n",
        "    scale_y_continuous(\n",
        "      name     = \"Température (°C)\",\n",
        "      limits   = c(0, max(data_site$pluie_mm / coef, na.rm = TRUE) + 5),\n",
        "      sec.axis = sec_axis(~ . * coef,\n",
        "                          name   = \"Précipitations (mm)\",\n",
        "                          breaks = seq(0, 300, 50))\n",
        "    ) +\n",
        "\n",
        "    # ── Annotations saisons ──\n",
        "    annotate(\"text\", x = 5.5, y = 1.5,\n",
        "             label = \"Saison humide\",\n",
        "             size = 2.8, color = \"#2980B9\", fontface = \"italic\") +\n",
        "    annotate(\"text\", x = 1.5, y = 1.5,\n",
        "             label = \"Saison\\nsèche\",\n",
        "             size = 2.5, color = \"#C8912A\", fontface = \"italic\") +\n",
        "\n",
        "    # ── Thème ──\n",
        "    theme_minimal(base_size = 10) +\n",
        "    theme(\n",
        "      panel.grid.major.x = element_blank(),\n",
        "      panel.grid.minor   = element_blank(),\n",
        "      axis.text.x  = element_text(angle = 45, hjust = 1, size = 8),\n",
        "      axis.title.y       = element_text(color = couleur, face = \"bold\", size = 9),\n",
        "      axis.title.y.right = element_text(color = \"#2980B9\", face = \"bold\", size = 9),\n",
        "      plot.title   = element_text(size = 10, face = \"bold\", hjust = 0.5,\n",
        "                                  color = couleur),\n",
        "      plot.subtitle = element_text(size = 8, hjust = 0.5, color = \"#555555\"),\n",
        "      plot.background = element_rect(fill = \"white\", color = couleur,\n",
        "                                     linewidth = 0.8)\n",
        "    ) +\n",
        "    labs(\n",
        "      title    = paste0(\"Climogramme — \", nom_site),\n",
        "      subtitle = paste0(\"T° moy. annuelle : \",\n",
        "                        round(mean(data_site$T_moy), 1), \" °C  |  \",\n",
        "                        \"Pluies annuelles : \",\n",
        "                        sum(data_site$pluie_mm), \" mm\"),\n",
        "      x = NULL,\n",
        "      y = \"Température (°C)\"\n",
        "    )\n",
        "}\n",
        "\n",
        "# Opérateur %||% (si non disponible)\n",
        "`%||%` <- function(a, b) if (!is.null(a)) a else b\n",
        "\n",
        "climo_daloa      <- make_climogramme(daloa_clim,      \"Daloa\",      \"#C0392B\")\n",
        "climo_zoukougbeu <- make_climogramme(zoukougbeu_clim, \"Zoukougbeu\", \"#E67E22\")\n",
        "climo_gonante    <- make_climogramme(gonante_clim,    \"Gonaté\",     \"#27AE60\")\n",
        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "# 3. GRAPHIQUE HUMIDITÉ RELATIVE ─ COMPARAISON DES 3 SITES\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "graph_HR <- ggplot(all_clim, aes(x = mois_num, y = HR_pct, color = site)) +\n",
        "\n",
        "  # Zone optimale BSF (70-85%)\n",
        "  annotate(\"rect\",\n",
        "           xmin = 0.5, xmax = 12.5,\n",
        "           ymin = 70,  ymax = 85,\n",
        "           fill = \"#27AE60\", alpha = 0.08) +\n",
        "  annotate(\"text\", x = 12.3, y = 77.5,\n",
        "           label = \"Optimum BSF\\n(70-85%)\",\n",
        "           size = 2.8, color = \"#27AE60\",\n",
        "           fontface = \"italic\", hjust = 1) +\n",
        "\n",
        "  # Zone optimale T. molitor (60-75%)\n",
        "  annotate(\"rect\",\n",
        "           xmin = 0.5, xmax = 12.5,\n",
        "           ymin = 60,  ymax = 75,\n",
        "           fill = \"#E67E22\", alpha = 0.08) +\n",
        "  annotate(\"text\", x = 0.7, y = 67.5,\n",
        "           label = \"Optimum\\nT. molitor\\n(60-75%)\",\n",
        "           size = 2.8, color = \"#E67E22\",\n",
        "           fontface = \"italic\", hjust = 0) +\n",
        "\n",
        "  geom_line(aes(group = site), linewidth = 1.3) +\n",
        "  geom_point(size = 3, shape = 21, fill = \"white\", stroke = 1.5) +\n",
        "  geom_text(aes(label = HR_pct),\n",
        "            vjust  = -0.8,\n",
        "            size   = 2.5,\n",
        "            fontface = \"bold\") +\n",
        "\n",
        "  scale_color_manual(name = \"Site d'étude\", values = pal_sites) +\n",
        "  scale_x_continuous(breaks = 1:12, labels = mois) +\n",
        "  scale_y_continuous(limits = c(55, 95),\n",
        "                     breaks = seq(55, 95, 5),\n",
        "                     labels = function(x) paste0(x, \"%\")) +\n",
        "\n",
        "  # Lignes de référence\n",
        "  geom_hline(yintercept = 70, linetype = \"dashed\",\n",
        "             color = \"#27AE60\", linewidth = 0.5) +\n",
        "  geom_hline(yintercept = 85, linetype = \"dashed\",\n",
        "             color = \"#27AE60\", linewidth = 0.5) +\n",
        "  geom_hline(yintercept = 60, linetype = \"dotted\",\n",
        "             color = \"#E67E22\", linewidth = 0.5) +\n",
        "  geom_hline(yintercept = 75, linetype = \"dotted\",\n",
        "             color = \"#E67E22\", linewidth = 0.5) +\n",
        "\n",
        "  theme_minimal(base_size = 10) +\n",
        "  theme(\n",
        "    panel.grid.minor   = element_blank(),\n",
        "    axis.text.x  = element_text(angle = 45, hjust = 1),\n",
        "    legend.position    = \"top\",\n",
        "    legend.title = element_text(face = \"bold\"),\n",
        "    plot.title   = element_text(size = 11, face = \"bold\", hjust = 0.5),\n",
        "    plot.subtitle = element_text(size = 9, face = \"italic\",\n",
        "                                 hjust = 0.5, color = \"#555555\")\n",
        "  ) +\n",
        "  labs(\n",
        "    title    = \"Humidité relative mensuelle — Comparaison des 3 sites d'étude\",\n",
        "    subtitle = \"Zones optimales pour le développement larvaire de H. illucens et T. molitor\",\n",
        "    x        = NULL,\n",
        "    y        = \"Humidité relative (%)\"\n",
        "  )\n",
        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "# 4. GRAPHIQUE TEMPÉRATURES MOYENNES COMPARÉES\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "graph_T <- ggplot(daloa_clim, aes(x = mois_num)) +\n",
        "\n",
        "  # Enveloppe min-max\n",
        "  geom_ribbon(aes(ymin = T_min, ymax = T_max),\n",
        "              fill  = \"#FADBD8\",\n",
        "              alpha = 0.5) +\n",
        "\n",
        "  # Courbe T_max\n",
        "  geom_line(aes(y = T_max, linetype = \"T. maximale\"),\n",
        "            color = \"#C0392B\", linewidth = 1.0) +\n",
        "\n",
        "  # Courbe T_min\n",
        "  geom_line(aes(y = T_min, linetype = \"T. minimale\"),\n",
        "            color = \"#2980B9\", linewidth = 1.0) +\n",
        "\n",
        "  # Courbe T_moy\n",
        "  geom_line(aes(y = T_moy, linetype = \"T. moyenne\"),\n",
        "            color = \"#E67E22\", linewidth = 1.4) +\n",
        "  geom_point(aes(y = T_moy),\n",
        "             color = \"#E67E22\", size = 2.5, shape = 21, fill = \"white\", stroke = 1.5) +\n",
        "\n",
        "  # Zone optimale BSF\n",
        "  annotate(\"rect\",\n",
        "           xmin = 0.5, xmax = 12.5,\n",
        "           ymin = 27,  ymax = 32,\n",
        "           fill = \"#27AE60\", alpha = 0.10) +\n",
        "  annotate(\"text\", x = 12.3, y = 29.5,\n",
        "           label = \"Zone optimale\\nH. illucens\\n(27-32°C)\",\n",
        "           size = 2.8, color = \"#27AE60\",\n",
        "           fontface = \"italic\", hjust = 1) +\n",
        "\n",
        "  # Zone optimale T. molitor\n",
        "  annotate(\"rect\",\n",
        "           xmin = 0.5, xmax = 12.5,\n",
        "           ymin = 25,  ymax = 32,\n",
        "           fill = \"#E67E22\", alpha = 0.06) +\n",
        "\n",
        "  scale_linetype_manual(\n",
        "    name   = \"Type de température\",\n",
        "    values = c(\"T. maximale\" = \"dotted\",\n",
        "               \"T. minimale\" = \"dashed\",\n",
        "               \"T. moyenne\"  = \"solid\")\n",
        "  ) +\n",
        "  scale_x_continuous(breaks = 1:12, labels = mois) +\n",
        "  scale_y_continuous(limits = c(16, 38),\n",
        "                     breaks = seq(16, 38, 2),\n",
        "                     labels = function(y) paste0(y, \" °C\")) +\n",
        "\n",
        "  theme_minimal(base_size = 10) +\n",
        "  theme(\n",
        "    panel.grid.minor   = element_blank(),\n",
        "    axis.text.x  = element_text(angle = 45, hjust = 1),\n",
        "    legend.position    = \"top\",\n",
        "    legend.title = element_text(face = \"bold\"),\n",
        "    plot.title   = element_text(size = 11, face = \"bold\", hjust = 0.5),\n",
        "    plot.subtitle = element_text(size = 9, face = \"italic\",\n",
        "                                 hjust = 0.5, color = \"#555555\")\n",
        "  ) +\n",
        "  labs(\n",
        "    title    = \"Régime thermique mensuel — Station de Daloa (représentative du Haut Sassandra)\",\n",
        "    subtitle = \"Données SODEXAM — Moyennes 1991-2020\",\n",
        "    x        = NULL,\n",
        "    y        = \"Température (°C)\"\n",
        "  )\n",
        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "# 5. CARTE AVEC ISOHYÈTES (ZONES DE PLUIES)\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "cote_ivoire <- ne_countries(country = \"Ivory Coast\", scale = \"large\",\n",
        "                            returnclass = \"sf\")\n",
        "voisins     <- ne_countries(\n",
        "  country = c(\"Ghana\", \"Liberia\", \"Guinea\", \"Mali\", \"Burkina Faso\"),\n",
        "  scale   = \"medium\", returnclass = \"sf\"\n",
        ")\n",
        "\n",
        "coords <- data.frame(\n",
        "  site      = c(\"Daloa\", \"Zoukougbeu\", \"Gonaté\"),\n",
        "  longitude = c(-6.4500, -6.9000, -6.6500),\n",
        "  latitude  = c(6.8833,   6.9500,  6.6500),\n",
        "  pluie_ann = c(1166,    1097,     1130),\n",
        "  T_ann     = c(26.8,    26.8,     26.8)\n",
        ")\n",
        "\n",
        "# Zones climatiques simplifiées de Côte d'Ivoire\n",
        "# (représentées par des annotations annotées)\n",
        "zones_clim <- data.frame(\n",
        "  label = c(\"Climat équatorial\\natténué\\n(> 1600 mm/an)\",\n",
        "            \"Climat tropical\\nde transition\\n(1200-1600 mm/an)\",\n",
        "            \"Climat tropical\\nsudano-sahélien\\n(< 1200 mm/an)\",\n",
        "            \"Zone\\nd'étude\"),\n",
        "  x     = c(-4.5, -6.5, -6.0, -6.65),\n",
        "  y     = c(5.8,   7.0,  9.5,  7.95),\n",
        "  color = c(\"#1A7A4A\", \"#2980B9\", \"#E67E22\", \"#C0392B\")\n",
        ")\n",
        "\n",
        "carte_climat <- ggplot() +\n",
        "\n",
        "  geom_sf(data = voisins,\n",
        "          fill = \"#F5F0E8\", color = \"#CCCCCC\", linewidth = 0.3) +\n",
        "\n",
        "  geom_sf(data = cote_ivoire,\n",
        "          fill = \"#EAF5E3\", color = \"#3D7A3D\", linewidth = 0.7) +\n",
        "\n",
        "  # Isohyètes approximatives (lignes de pluies égales)\n",
        "  # Zone humide sud (> 1800 mm)\n",
        "  annotate(\"path\",\n",
        "           x = c(-8.5, -7.5, -6.0, -4.5, -3.0, -2.5),\n",
        "           y = c(5.5,   5.2,  5.0,  5.1,  5.0,  5.2),\n",
        "           color = \"#1A7A4A\", linewidth = 0.8, linetype = \"longdash\") +\n",
        "  annotate(\"text\", x = -8.3, y = 5.4,\n",
        "           label = \"1800 mm\", size = 2.5, color = \"#1A7A4A\",\n",
        "           fontface = \"italic\") +\n",
        "\n",
        "  # 1400 mm\n",
        "  annotate(\"path\",\n",
        "           x = c(-8.5, -7.8, -6.5, -5.0, -3.5, -2.5),\n",
        "           y = c(7.0,   7.2,  6.8,  6.5,  6.2,  6.0),\n",
        "           color = \"#2980B9\", linewidth = 0.8, linetype = \"longdash\") +\n",
        "  annotate(\"text\", x = -8.3, y = 7.0,\n",
        "           label = \"1400 mm\", size = 2.5, color = \"#2980B9\",\n",
        "           fontface = \"italic\") +\n",
        "\n",
        "  # 1200 mm (passe par la zone d'étude)\n",
        "  annotate(\"path\",\n",
        "           x = c(-8.5, -7.5, -6.5, -5.8, -5.0, -4.0, -3.0, -2.5),\n",
        "           y = c(8.5,   8.2,  7.8,  7.5,  7.2,  7.0,  7.1,  7.3),\n",
        "           color = \"#E67E22\", linewidth = 1.0, linetype = \"longdash\") +\n",
        "  annotate(\"text\", x = -8.3, y = 8.6,\n",
        "           label = \"1200 mm\", size = 2.5, color = \"#E67E22\",\n",
        "           fontface = \"italic\") +\n",
        "\n",
        "  # Zone d'étude\n",
        "  annotate(\"rect\",\n",
        "           xmin = -7.5, xmax = -5.8,\n",
        "           ymin = 6.3, ymax = 7.7,\n",
        "           fill  = \"#FFF5E6\",\n",
        "           color = \"#C0392B\",\n",
        "           linewidth = 1.2,\n",
        "           alpha = 0.5) +\n",
        "  annotate(\"text\", x = -6.65, y = 7.82,\n",
        "           label = \"Zone d'étude\\n(Haut Sassandra)\",\n",
        "           size = 3.2, color = \"#C0392B\", fontface = \"bold.italic\") +\n",
        "\n",
        "  # Sites d'étude\n",
        "  geom_point(data = coords,\n",
        "             aes(x = longitude, y = latitude),\n",
        "             shape = 21, size = 5, fill = \"#C0392B\",\n",
        "             color = \"white\", stroke = 1.5) +\n",
        "  geom_text(data = coords,\n",
        "            aes(x = longitude, y = latitude + 0.18, label = site),\n",
        "            size = 3, fontface = \"bold\", color = \"#C0392B\") +\n",
        "  geom_text(data = coords,\n",
        "            aes(x = longitude, y = latitude - 0.18,\n",
        "                label = paste0(pluie_ann, \" mm/an\")),\n",
        "            size = 2.8, fontface = \"italic\", color = \"#2980B9\") +\n",
        "\n",
        "  annotation_scale(location = \"br\", width_hint = 0.25) +\n",
        "  annotation_north_arrow(location = \"tr\", which_north = \"true\",\n",
        "                         height = unit(1.0, \"cm\"), width = unit(1.0, \"cm\")) +\n",
        "\n",
        "  scale_x_continuous(breaks = seq(-8.5, -2.5, 1),\n",
        "                     labels = function(x) paste0(abs(x), \"°O\")) +\n",
        "  scale_y_continuous(breaks = seq(4, 11, 1),\n",
        "                     labels = function(y) paste0(y, \"°N\")) +\n",
        "\n",
        "  coord_sf(xlim = c(-8.7, -2.4), ylim = c(4.2, 10.8), expand = FALSE) +\n",
        "\n",
        "  theme_bw(base_size = 10) +\n",
        "  theme(\n",
        "    panel.background = element_rect(fill = \"#D6EBF5\"),\n",
        "    panel.grid.major = element_line(color = \"#CCDDEE\", linewidth = 0.3,\n",
        "                                    linetype = \"dotted\"),\n",
        "    axis.title = element_blank(),\n",
        "    plot.title = element_text(size = 10, face = \"bold\", hjust = 0.5)\n",
        "  ) +\n",
        "  labs(title = \"Zones pluviométriques\\net localisation de la zone d'étude\")\n",
        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "# 6. ASSEMBLAGE FINAL ─ PLANCHE CLIMATIQUE\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "# Titre général\n",
        "titre <- ggdraw() + draw_label(\n",
        "  \"Caractéristiques climatiques de la zone d'étude — Haut Sassandra, Côte d'Ivoire\",\n",
        "  fontface = \"bold\", size = 14, x = 0.5, hjust = 0.5\n",
        ")\n",
        "sous_titre <- ggdraw() + draw_label(\n",
        "  \"Données SODEXAM | Moyennes 1991-2020 | Station synoptique de Daloa (OMM 65506)\",\n",
        "  fontface = \"italic\", size = 9, color = \"#555555\", x = 0.5, hjust = 0.5\n",
        ")\n",
        "\n",
        "# Rangée 1 : carte clima + climogramme Daloa\n",
        "row1 <- plot_grid(\n",
        "  carte_climat,\n",
        "  climo_daloa,\n",
        "  ncol = 2, rel_widths = c(1, 1.2),\n",
        "  labels = c(\"A\", \"B\"), label_size = 12, label_fontface = \"bold\"\n",
        ")\n",
        "\n",
        "# Rangée 2 : climogrammes Zoukougbeu + Gonaté\n",
        "row2 <- plot_grid(\n",
        "  climo_zoukougbeu,\n",
        "  climo_gonante,\n",
        "  ncol = 2,\n",
        "  labels = c(\"C\", \"D\"), label_size = 12, label_fontface = \"bold\"\n",
        ")\n",
        "\n",
        "# Rangée 3 : T° + HR\n",
        "row3 <- plot_grid(\n",
        "  graph_T,\n",
        "  graph_HR,\n",
        "  ncol = 2,\n",
        "  labels = c(\"E\", \"F\"), label_size = 12, label_fontface = \"bold\"\n",
        ")\n",
        "\n",
        "planche_clim <- plot_grid(\n",
        "  titre, sous_titre,\n",
        "  row1, row2, row3,\n",
        "  ncol        = 1,\n",
        "  rel_heights = c(0.05, 0.03, 1, 0.9, 0.85)\n",
        ")\n",
        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "# 7. EXPORT\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "ggsave(\"outputs/cartes/Fig04_Climatologie_Zone_Etude.png\",\n",
        "       plot = planche_clim,\n",
        "       width = 40, height = 48, units = \"cm\", dpi = 300, bg = \"white\")\n",
        "\n",
        "ggsave(\"outputs/cartes/Fig04_Climatologie_Zone_Etude.pdf\",\n",
        "       plot = planche_clim,\n",
        "       width = 40, height = 48, units = \"cm\")\n",
        "\n",
        "cat(\"=== Fig04 exportée ===\\n\")\n",
        "cat(\"  → outputs/cartes/Fig04_Climatologie_Zone_Etude.png\\n\")\n",
        "cat(\"  → outputs/cartes/Fig04_Climatologie_Zone_Etude.pdf\\n\")"
