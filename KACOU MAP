      "cell_type": "code",
      "source": [
        "# =============================================================================\n",
        "# SCRIPT 03 — CARTE DÉTAILLÉE DE LA ZONE D'ÉTUDE\n",
        "# Contexte climatique, relief, hydrographie et sites d'échantillonnage\n",
        "# =============================================================================\n",
        "# Produit : Carte détaillée du Haut Sassandra avec :\n",
        "#   - Limites administratives\n",
        "#   - Hydrographie (fleuve Sassandra et affluents)\n",
        "#   - Principaux axes routiers\n",
        "#   - Sites de collecte annotés\n",
        "#   - Encart de localisation en médaillon\n",
        "# =============================================================================\n",
        "\n",
        "library(sf)\n",
        "library(ggplot2)\n",
        "library(ggspatial)\n",
        "library(rnaturalearth)\n",
        "library(rnaturalearthdata)\n",
        "library(dplyr)\n",
        "library(ggrepel)\n",
        "library(cowplot)\n",
        "library(RColorBrewer)\n",
        "library(viridis)\n",
        "library(scales)\n",
        "\n",
        "# ── 1. DONNÉES DES SITES D'ÉTUDE ─────────────────────────────────────────────\n",
        "\n",
        "sites <- data.frame(\n",
        "  nom        = c(\"Daloa\", \"Zoukougbeu\", \"Gonaté\"),\n",
        "  departement = c(\"Daloa\", \"Zoukougbeu\", \"Issia\"),\n",
        "  type       = c(\"Urbain\", \"Semi-urbain\", \"Rural\"),\n",
        "  longitude  = c(-6.4500, -6.9000, -6.6500),\n",
        "  latitude   = c(6.8833,   6.9500,   6.6500),\n",
        "  population = c(350000,    60000,     5000),\n",
        "  altitude   = c(320,       285,       295),\n",
        "  statut_collecte = c(\"Site principal\", \"Site secondaire\", \"Site rural\"),\n",
        "  stringsAsFactors = FALSE\n",
        ")\n",
        "\n",
        "# Villes de référence supplémentaires\n",
        "villes_ref <- data.frame(\n",
        "  nom       = c(\"Issia\", \"Vavoua\", \"Bouaflé\", \"Man\", \"Gagnoa\", \"Sassandra\"),\n",
        "  longitude = c(-6.5800, -6.4800, -5.7500, -7.5500, -5.9500, -6.0800),\n",
        "  latitude  = c(6.4800,   7.3800,  6.9833,   7.4333,  5.9600,   4.9600),\n",
        "  stringsAsFactors = FALSE\n",
        ")\n",
        "\n",
        "sites_sf     <- st_as_sf(sites,    coords = c(\"longitude\", \"latitude\"), crs = 4326)\n",
        "villes_sf    <- st_as_sf(villes_ref, coords = c(\"longitude\", \"latitude\"), crs = 4326)\n",
        "\n",
        "# ── 2. GÉOGRAPHIES DE BASE ────────────────────────────────────────────────────\n",
        "\n",
        "cote_ivoire <- ne_countries(country = \"Ivory Coast\", scale = \"large\",  returnclass = \"sf\")\n",
        "pays_voisins <- ne_countries(\n",
        "  country = c(\"Ghana\", \"Liberia\", \"Guinea\", \"Mali\", \"Burkina Faso\"),\n",
        "  scale   = \"medium\", returnclass = \"sf\"\n",
        ")\n",
        "\n",
        "# ── 3. HYDROGRAPHIE SIMULÉE (Fleuve Sassandra + affluents) ───────────────────\n",
        "# Note : si vous avez un shapefile hydrographique réel (HydroSHEDS, OpenStreetMap),\n",
        "#        remplacez ces lignes par : rivers <- st_read(\"data/shapefiles/hydrographie.shp\")\n",
        "\n",
        "fleuve_sassandra <- data.frame(\n",
        "  lon = c(-6.10, -6.12, -6.08, -6.11, -6.09, -6.08, -6.10),\n",
        "  lat = c(7.80,  7.50,  7.20,  6.90,  6.60,  6.30,  4.96)\n",
        ")\n",
        "\n",
        "affluent_loh <- data.frame(\n",
        "  lon = c(-6.90, -6.70, -6.50, -6.20, -6.10),\n",
        "  lat = c(7.50,  7.30,  7.10,  6.95,  6.90)\n",
        ")\n",
        "\n",
        "affluent_dibo <- data.frame(\n",
        "  lon = c(-6.80, -6.60, -6.40, -6.20, -6.10),\n",
        "  lat = c(6.70,  6.65,  6.60,  6.70,  6.60)\n",
        ")\n",
        "\n",
        "affluent_lobo <- data.frame(\n",
        "  lon = c(-6.50, -6.35, -6.20, -6.10),\n",
        "  lat = c(6.40,  6.50,  6.45,  6.30)\n",
        ")\n",
        "\n",
        "# ── 4. AXES ROUTIERS PRINCIPAUX (approximatifs) ───────────────────────────────\n",
        "# Note : si vous avez un shapefile routier, utilisez : roads <- st_read(...)\n",
        "\n",
        "route_daloa_abidjan <- data.frame(\n",
        "  lon = c(-6.45, -6.20, -5.80, -5.40, -4.90, -4.20, -4.02),\n",
        "  lat = c(6.88,  6.80,  6.70,  6.50,  6.20,  5.60,  5.32)\n",
        ")\n",
        "\n",
        "route_daloa_man <- data.frame(\n",
        "  lon = c(-6.45, -6.80, -7.10, -7.55),\n",
        "  lat = c(6.88,  7.10,  7.30,  7.43)\n",
        ")\n",
        "\n",
        "route_daloa_zoukougbeu <- data.frame(\n",
        "  lon = c(-6.45, -6.60, -6.75, -6.90),\n",
        "  lat = c(6.88,  6.90,  6.93,  6.95)\n",
        ")\n",
        "\n",
        "route_daloa_gagnoa <- data.frame(\n",
        "  lon = c(-6.45, -6.30, -6.10, -5.95),\n",
        "  lat = c(6.88,  6.70,  6.40,  5.96)\n",
        ")\n",
        "\n",
        "# ── 5. CARTE PRINCIPALE ───────────────────────────────────────────────────────\n",
        "\n",
        "pal_type <- c(\n",
        "  \"Urbain\"      = \"#C0392B\",\n",
        "  \"Semi-urbain\" = \"#E67E22\",\n",
        "  \"Rural\"       = \"#27AE60\"\n",
        ")\n",
        "\n",
        "carte_detail <- ggplot() +\n",
        "\n",
        "  # ── Pays voisins (contexte) ──\n",
        "  geom_sf(data = pays_voisins,\n",
        "          fill  = \"#F0EDE5\",\n",
        "          color = \"#C0C0C0\",\n",
        "          linewidth = 0.4) +\n",
        "\n",
        "  # ── Côte d'Ivoire ──\n",
        "  geom_sf(data = cote_ivoire,\n",
        "          fill  = \"#EAF2E3\",\n",
        "          color = \"#3D7A3D\",\n",
        "          linewidth = 0.8) +\n",
        "\n",
        "  # ── Zone d'étude — Haut Sassandra (rectangle coloré) ──\n",
        "  annotate(\"rect\",\n",
        "           xmin = -7.50, xmax = -5.80,\n",
        "           ymin =  6.30, ymax =  7.70,\n",
        "           fill = \"#FDFBE4\",\n",
        "           color = \"#C0392B\",\n",
        "           linewidth = 1.0,\n",
        "           alpha = 0.5) +\n",
        "\n",
        "  # ── Hydrographie ──\n",
        "  geom_path(data = fleuve_sassandra,\n",
        "            aes(x = lon, y = lat),\n",
        "            color = \"#3B82C4\",\n",
        "            linewidth = 1.4) +\n",
        "  geom_path(data = affluent_loh,\n",
        "            aes(x = lon, y = lat),\n",
        "            color = \"#5B9BD5\",\n",
        "            linewidth = 0.8) +\n",
        "  geom_path(data = affluent_dibo,\n",
        "            aes(x = lon, y = lat),\n",
        "            color = \"#5B9BD5\",\n",
        "            linewidth = 0.7) +\n",
        "  geom_path(data = affluent_lobo,\n",
        "            aes(x = lon, y = lat),\n",
        "            color = \"#5B9BD5\",\n",
        "            linewidth = 0.6) +\n",
        "\n",
        "  # Étiquettes fleuve\n",
        "  annotate(\"text\",\n",
        "           x = -5.85, y = 6.5,\n",
        "           label = \"Fl. Sassandra\",\n",
        "           angle = 85,\n",
        "           size  = 3,\n",
        "           color = \"#2C67A8\",\n",
        "           fontface = \"italic\") +\n",
        "  annotate(\"text\",\n",
        "           x = -6.55, y = 7.2,\n",
        "           label = \"Lôh\",\n",
        "           size  = 2.8,\n",
        "           color = \"#5B9BD5\",\n",
        "           fontface = \"italic\",\n",
        "           angle = 15) +\n",
        "  annotate(\"text\",\n",
        "           x = -6.55, y = 6.55,\n",
        "           label = \"Dibo\",\n",
        "           size  = 2.8,\n",
        "           color = \"#5B9BD5\",\n",
        "           fontface = \"italic\",\n",
        "           angle = 5) +\n",
        "\n",
        "  # ── Axes routiers ──\n",
        "  geom_path(data = route_daloa_abidjan,\n",
        "            aes(x = lon, y = lat),\n",
        "            color     = \"#888888\",\n",
        "            linewidth = 0.9,\n",
        "            linetype  = \"solid\") +\n",
        "  geom_path(data = route_daloa_man,\n",
        "            aes(x = lon, y = lat),\n",
        "            color     = \"#888888\",\n",
        "            linewidth = 0.9) +\n",
        "  geom_path(data = route_daloa_zoukougbeu,\n",
        "            aes(x = lon, y = lat),\n",
        "            color     = \"#AAAAAA\",\n",
        "            linewidth = 0.7,\n",
        "            linetype  = \"dashed\") +\n",
        "  geom_path(data = route_daloa_gagnoa,\n",
        "            aes(x = lon, y = lat),\n",
        "            color     = \"#888888\",\n",
        "            linewidth = 0.8) +\n",
        "\n",
        "  # Labels routes\n",
        "  annotate(\"text\", x = -5.80, y = 6.20,\n",
        "           label = \"vers Abidjan →\",\n",
        "           size = 2.8, color = \"#666666\", fontface = \"italic\", hjust = 0) +\n",
        "  annotate(\"text\", x = -7.60, y = 7.48,\n",
