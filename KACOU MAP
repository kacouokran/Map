        "\n",
        "  # ── SITES D'ÉTUDE ──\n",
        "  # Halo autour des sites\n",
        "  geom_point(data = sites,\n",
        "             aes(x = longitude, y = latitude, color = type),\n",
        "             shape = 21,\n",
        "             size  = 12,\n",
        "             fill  = NA,\n",
        "             stroke = 0.4,\n",
        "             alpha = 0.3) +\n",
        "\n",
        "  # Points principaux\n",
        "  geom_point(data = sites,\n",
