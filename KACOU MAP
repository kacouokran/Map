        "  height   = 30,\n",
        "  units    = \"cm\"\n",
        ")\n",
        "\n",
        "cat(\"=== Fig03 exportée ===\\n\")\n",
        "cat(\"  → outputs/cartes/Fig03_Carte_Thematique_Sites.png\\n\")"
