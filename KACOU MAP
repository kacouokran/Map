        "  ) +\n",
        "  labs(\n",
        "    title    = \"Zone d'étude : Région du Haut Sassandra — Côte d'Ivoire\",\n",
        "    subtitle = \"Sites de collecte des déchets organiques ménagers pour l'élevage de Hermetia illucens et Tenebrio molitor\",\n",
