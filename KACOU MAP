        "# =============================================================================\n",
        "# SCRIPT 01 — INSTALLATION DES PACKAGES ET CONFIGURATION GÉNÉRALE\n",
        "# Thèse : Étude métagénomique des biofertilisants — Haut Sassandra, CI\n",
        "# Auteur  : [Votre nom]\n",
        "# Date    : 2024-2025\n",
        "# =============================================================================\n",
        "# Ce script installe tous les packages nécessaires à la cartographie.\n",
        "# À exécuter UNE SEULE FOIS avant les autres scripts.\n",
        "# =============================================================================\n",
        "\n",
        "# ── 1. LISTE DES PACKAGES NÉCESSAIRES ────────────────────────────────────────\n",
        "\n",
        "packages_carto <- c(\n",
        "  # Manipulation et lecture de données spatiales\n",
        "  \"sf\",            # Vecteur (shapefile, GeoJSON)\n",
        "  \"terra\",         # Raster (remplace raster + rgdal)\n",
        "  \"sp\",            # Classes spatiales (compatibilité)\n",
        "\n",
        "  # Visualisation cartographique\n",
        "  \"ggplot2\",       # Visualisation base\n",
        "  \"ggmap\",         # Fonds de carte Google / Stamen\n",
        "  \"ggspatial\",     # Flèche nord, échelle, annotations spatiales\n",
        "  \"cowplot\",       # Assemblage de cartes\n",
        "  \"patchwork\",     # Assemblage de graphiques\n",
        "  \"tmap\",          # Cartographie thématique\n",
        "\n",
        "  # Données géographiques libres (pays, régions)\n",
        "  \"rnaturalearth\",      # Frontières pays / continents\n",
        "  \"rnaturalearthdata\",  # Données haute résolution\n",
        "  \"geodata\",            # Données GADM (limites admin)\n",
        "\n",
        "  # Palettes de couleurs\n",
        "  \"RColorBrewer\",  # Palettes cartographiques\n",
        "  \"viridis\",       # Palettes perceptuellement uniformes\n",
        "  \"scales\",        # Mise en forme des axes et couleurs\n",
        "\n",
        "  # Manipulation des données\n",
        "  \"dplyr\",         # Manipulation dataframes\n",
        "  \"tidyr\",         # Mise en forme longue/large\n",
        "  \"readxl\",        # Lecture fichiers Excel\n",
        "\n",
        "  # Annotations et exports\n",
        "  \"ggrepel\",       # Étiquettes non chevauchantes\n",
        "  \"extrafont\",     # Polices supplémentaires\n",
        "  \"gridExtra\",     # Assemblage de graphiques\n",
        "  \"png\",           # Lecture/écriture PNG\n",
        "  \"jpeg\"           # Lecture/écriture JPEG\n",
        ")\n",
        "\n",
        "# ── 2. INSTALLATION AUTOMATIQUE ───────────────────────────────────────────────\n",
        "\n",
        "cat(\"=== Installation des packages cartographiques ===\\n\\n\")\n",
        "\n",
        "for (pkg in packages_carto) {\n",
        "  if (!requireNamespace(pkg, quietly = TRUE)) {\n",
        "    cat(sprintf(\"  Installation de : %s ...\\n\", pkg))\n",
        "    install.packages(pkg, dependencies = TRUE,\n",
        "                     repos = \"https://cloud.r-project.org\")\n",
        "  } else {\n",
        "    cat(sprintf(\"  [OK] %s déjà installé\\n\", pkg))\n",
        "  }\n",
        "}\n",
        "\n",
        "# Package rnaturalearthdata (depuis GitHub si nécessaire)\n",
        "if (!requireNamespace(\"rnaturalearthdata\", quietly = TRUE)) {\n",
        "  install.packages(\"rnaturalearthdata\",\n",
        "                   repos = \"https://ropensci.r-universe.dev\")\n",
        "}\n",
        "\n",
        "cat(\"\\n=== Tous les packages sont prêts ===\\n\")\n",
        "\n",
        "# ── 3. CHARGEMENT ET VÉRIFICATION ────────────────────────────────────────────\n",
        "\n",
        "suppressPackageStartupMessages({\n",
        "  library(sf)\n",
        "  library(terra)\n",
        "  library(ggplot2)\n",
        "  library(ggspatial)\n",
        "  library(rnaturalearth)\n",
        "  library(rnaturalearthdata)\n",
        "  library(dplyr)\n",
        "  library(RColorBrewer)\n",
        "  library(viridis)\n",
        "  library(ggrepel)\n",
        "})\n",
        "\n",
        "cat(\"\\n=== Packages chargés avec succès ===\\n\")\n",
        "cat(sprintf(\"  Version R       : %s\\n\", R.version$version.string))\n",
        "cat(sprintf(\"  Version sf      : %s\\n\", packageVersion(\"sf\")))\n",
        "cat(sprintf(\"  Version ggplot2 : %s\\n\", packageVersion(\"ggplot2\")))\n",
        "cat(sprintf(\"  Version terra   : %s\\n\", packageVersion(\"terra\")))\n",
        "\n",
        "# ── 4. CONFIGURATION DES RÉPERTOIRES DE TRAVAIL ───────────────────────────────\n",
        "\n",
        "# Modifier ce chemin selon votre organisation\n",
        "setwd(\"C:/These_HautSassandra/Cartographie\")  # Windows\n",
        "# setwd(\"~/These_HautSassandra/Cartographie\") # Mac/Linux\n",
        "\n",
        "# Création des sous-dossiers si absents\n",
        "dirs <- c(\"data/shapefiles\", \"data/raster\", \"data/csv\",\n",
        "          \"outputs/cartes\", \"outputs/figures\", \"scripts\")\n",
        "\n",
        "for (d in dirs) {\n",
        "  if (!dir.exists(d)) {\n",
        "    dir.create(d, recursive = TRUE)\n",
        "    cat(sprintf(\"  Dossier créé : %s\\n\", d))\n",
        "  }\n",
        "}\n",
        "\n",
        "cat(\"\\n=== Configuration terminée. Vous pouvez passer au Script 02. ===\\n\")"
