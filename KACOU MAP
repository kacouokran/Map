        "\n",
        "  geom_point(data = sites,\n",
        "             aes(x = longitude, y = latitude,\n",
        "                 color = type,\n",
        "                 size  = population / 4),\n",
        "             alpha = 0.8) +\n",
        "\n",
        "  # Étiquettes sites\n",
        "  geom_label_repel(\n",
