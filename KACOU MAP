      "cell_type": "code",
      "source": [
        "# =============================================================================\n",
        "# SCRIPT 04 — CARTE THÉMATIQUE DES SITES DE COLLECTE\n",
        "# Caractérisation des déchets organiques par localité\n",
        "# =============================================================================\n",
        "# Produit : Carte thématique avec graphiques en camembert sur chaque site,\n",
        "#           tableaux de caractérisation et profil climatique\n",
        "# =============================================================================\n",
        "\n",
        "library(sf)\n",
        "library(ggplot2)\n",
        "library(ggspatial)\n",
        "library(rnaturalearth)\n",
        "library(rnaturalearthdata)\n",
        "library(dplyr)\n",
        "library(tidyr)\n",
        "library(ggrepel)\n",
        "library(cowplot)\n",
        "library(RColorBrewer)\n",
        "library(scales)\n",
        "library(patchwork)   # install.packages(\"patchwork\") si nécessaire\n",
        "\n",
        "# ── 1. DONNÉES THÉMATIQUES DES SITES ─────────────────────────────────────────\n",
        "\n",
        "# Données physicochimiques attendues des déchets organiques ménagers\n",
        "physico <- data.frame(\n",
        "  site         = c(\"Daloa\", \"Zoukougbeu\", \"Gonaté\"),\n",
        "  teneur_eau   = c(73, 70, 67),      # % masse fraîche\n",
        "  mat_org      = c(79, 80, 82),      # % MS\n",
        "  azote_total  = c(2.3, 1.9, 1.5),  # % MS\n",
        "  CN_ratio     = c(20, 23, 26),      # Sans unité\n",
        "  pH           = c(6.1, 6.4, 6.7),  # eau 1:5\n",
        "  proteines    = c(14.5, 13.0, 11.0),# % MS\n",
        "  lipides      = c(7.2,  5.5,  4.1), # % MS\n",
        "  stringsAsFactors = FALSE\n",
        ")\n",
        "\n",
        "# Composition typique des déchets par site (% de chaque fraction)\n",
        "composition <- data.frame(\n",
        "  site = rep(c(\"Daloa\", \"Zoukougbeu\", \"Gonaté\"), each = 6),\n",
        "  fraction = rep(c(\"Légumes/Fruits\", \"Féculents\\n(igname, manioc)\",\n",
        "                   \"Restes de\\nrepas cuits\", \"Déchets\\nde poissons\",\n",
        "                   \"Légumineuses\", \"Autres\"), 3),\n",
        "  proportion = c(\n",
        "    # Daloa (urbain) — plus varié\n",
        "    28, 20, 22, 12, 10, 8,\n",
        "    # Zoukougbeu (semi-urbain)\n",
        "    25, 28, 20,  8, 12, 7,\n",
        "    # Gonaté (rural) — plus de féculents\n",
        "    20, 35, 18,  5, 15, 7\n",
        "  ),\n",
        "  stringsAsFactors = FALSE\n",
        ")\n",
        "\n",
        "# Données quantitatives : volumes de déchets générés (kg/ménage/jour)\n",
        "volumes <- data.frame(\n",
        "  site        = c(\"Daloa\", \"Zoukougbeu\", \"Gonaté\"),\n",
        "  kg_menage_j = c(1.8,    1.4,         0.9),\n",
        "  nb_menages  = c(70000,  12000,       1000),\n",
        "  total_t_j   = c(126,    16.8,        0.9),\n",
        "  stringsAsFactors = FALSE\n",
        ")\n",
        "\n",
        "# Coordonnées\n",
        "coords <- data.frame(\n",
        "  site      = c(\"Daloa\", \"Zoukougbeu\", \"Gonaté\"),\n",
        "  longitude = c(-6.4500, -6.9000, -6.6500),\n",
        "  latitude  = c(6.8833,   6.9500,  6.6500),\n",
        "  stringsAsFactors = FALSE\n",
        ")\n",
        "\n",
        "# ── 2. PALETTES ───────────────────────────────────────────────────────────────\n",
        "\n",
        "pal_fractions <- c(\n",
        "  \"Légumes/Fruits\"         = \"#27AE60\",\n",
        "  \"Féculents\\n(igname, manioc)\" = \"#E67E22\",\n",
        "  \"Restes de\\nrepas cuits\" = \"#E74C3C\",\n",
        "  \"Déchets\\nde poissons\"   = \"#2980B9\",\n",
        "  \"Légumineuses\"           = \"#8E44AD\",\n",
        "  \"Autres\"                 = \"#95A5A6\"\n",
        ")\n",
        "\n",
        "pal_sites <- c(\n",
        "  \"Daloa\"      = \"#C0392B\",\n",
        "  \"Zoukougbeu\" = \"#E67E22\",\n",
        "  \"Gonaté\"     = \"#27AE60\"\n",
        ")\n",
        "\n",
        "# ── 3. GRAPHIQUES EN CAMEMBERT PAR SITE ───────────────────────────────────────\n",
        "\n",
        "make_pie <- function(site_name, df_comp, pal) {\n",
        "  df <- df_comp %>% filter(site == site_name)\n",
        "  df$fraction_label <- paste0(df$fraction, \"\\n\", df$proportion, \"%\")\n",
        "\n",
        "  ggplot(df, aes(x = \"\", y = proportion, fill = fraction)) +\n",
        "    geom_col(width = 1, color = \"white\", linewidth = 0.5) +\n",
        "    coord_polar(\"y\", start = 0) +\n",
        "    scale_fill_manual(values = pal) +\n",
        "    theme_void() +\n",
        "    theme(\n",
        "      legend.position = \"none\",\n",
        "      plot.title = element_text(size = 9, face = \"bold\", hjust = 0.5,\n",
        "                                color = pal_sites[site_name])\n",
        "    ) +\n",
        "    labs(title = site_name)\n",
        "}\n",
        "\n",
        "pie_daloa      <- make_pie(\"Daloa\",      composition, pal_fractions)\n",
        "pie_zoukougbeu <- make_pie(\"Zoukougbeu\", composition, pal_fractions)\n",
        "pie_gonante    <- make_pie(\"Gonaté\",     composition, pal_fractions)\n",
        "\n",
        "# Légende commune\n",
        "legende_pie <- ggplot(composition, aes(x = \"\", y = proportion, fill = fraction)) +\n",
        "  geom_col() +\n",
        "  scale_fill_manual(name = \"Fraction organique\", values = pal_fractions) +\n",
        "  theme_void() +\n",
        "  theme(legend.position = \"right\",\n",
        "        legend.text  = element_text(size = 8),\n",
        "        legend.title = element_text(size = 9, face = \"bold\"))\n",
        "\n",
        "legende_extraite <- get_legend(legende_pie)\n",
        "\n",
        "# ── 4. GRAPHIQUE BARRES — VOLUMES DE DÉCHETS ─────────────────────────────────\n",
        "\n",
        "# Transformation pour visualisation\n",
        "volumes_long <- volumes %>%\n",
        "  mutate(\n",
        "    par_menage = kg_menage_j,\n",
        "    total      = total_t_j\n",
        "  )\n",
        "\n",
        "bar_volumes <- ggplot(volumes_long,\n",
        "                      aes(x = reorder(site, -total_t_j),\n",
        "                          y = kg_menage_j,\n",
        "                          fill = site)) +\n",
        "  geom_col(width = 0.55, color = \"white\", linewidth = 0.6) +\n",
        "  geom_text(aes(label = paste0(kg_menage_j, \" kg/mén./j\")),\n",
        "            vjust = -0.4, size = 3.5, fontface = \"bold\") +\n",
        "  scale_fill_manual(values = pal_sites, guide = \"none\") +\n",
        "  scale_y_continuous(expand = expansion(mult = c(0, 0.15))) +\n",
        "  labs(\n",
        "    title = \"Production de déchets par ménage\",\n",
        "    x = NULL,\n",
        "    y = \"kg de déchets / ménage / jour\"\n",
        "  ) +\n",
        "  theme_minimal(base_size = 10) +\n",
        "  theme(\n",
        "    panel.grid.major.x = element_blank(),\n",
        "    panel.grid.minor   = element_blank(),\n",
        "    axis.text.x  = element_text(face = \"bold\", size = 10),\n",
        "    plot.title   = element_text(size = 10, face = \"bold\", hjust = 0.5)\n",
        "  )\n",
        "\n",
        "# ── 5. GRAPHIQUE RADAR — PARAMÈTRES PHYSICOCHIMIQUES ─────────────────────────\n",
        "\n",
        "# Normalisation 0-100 pour chaque paramètre\n",
        "norm <- function(x) (x - min(x)) / (max(x) - min(x)) * 100\n",
        "\n",
        "physico_norm <- physico %>%\n",
        "  mutate(\n",
        "    teneur_eau_n  = norm(teneur_eau),\n",
        "    mat_org_n     = norm(mat_org),\n",
        "    azote_n       = norm(azote_total),\n",
        "    pH_n          = norm(pH),\n",
        "    proteines_n   = norm(proteines),\n",
        "    lipides_n     = norm(lipides)\n",
        "  ) %>%\n",
        "  select(site, ends_with(\"_n\"))\n",
        "\n",
        "# Version barres groupées (alternative au radar)\n",
        "physico_long <- physico %>%\n",
        "  pivot_longer(cols = c(teneur_eau, mat_org, azote_total, pH, proteines, lipides),\n",
        "               names_to  = \"parametre\",\n",
        "               values_to = \"valeur\") %>%\n",
        "  mutate(parametre = recode(parametre,\n",
        "    \"teneur_eau\"  = \"Teneur en\\neau (%)\",\n",
        "    \"mat_org\"     = \"Mat. org.\\n(%MS)\",\n",
        "    \"azote_total\" = \"Azote\\ntotal (%MS)\",\n",
        "    \"pH\"          = \"pH\\n(1:5 eau)\",\n",
        "    \"proteines\"   = \"Protéines\\n(%MS)\",\n",
        "    \"lipides\"     = \"Lipides\\n(%MS)\"\n",
        "  ))\n",
        "\n",
        "bar_physico <- ggplot(physico_long,\n",
        "                      aes(x = parametre, y = valeur,\n",
        "                          fill = site)) +\n",
        "  geom_col(position = position_dodge(width = 0.7),\n",
        "           width = 0.65,\n",
        "           color = \"white\",\n",
        "           linewidth = 0.3) +\n",
        "  geom_text(aes(label = valeur),\n",
        "            position  = position_dodge(width = 0.7),\n",
        "            vjust     = -0.4,\n",
        "            size      = 2.5,\n",
        "            fontface  = \"bold\") +\n",
        "  scale_fill_manual(name   = \"Site d'étude\",\n",
        "                    values = pal_sites) +\n",
        "  scale_y_continuous(expand = expansion(mult = c(0, 0.15))) +\n",
        "  labs(\n",
        "    title = \"Paramètres physicochimiques des déchets organiques ménagers\",\n",
        "    x = NULL,\n",
        "    y = \"Valeur (selon l'unité)\"\n",
        "  ) +\n",
        "  theme_minimal(base_size = 10) +\n",
        "  theme(\n",
        "    panel.grid.major.x = element_blank(),\n",
        "    panel.grid.minor   = element_blank(),\n",
        "    axis.text.x  = element_text(size = 8),\n",
        "    legend.position    = \"right\",\n",
        "    legend.title = element_text(face = \"bold\", size = 9),\n",
        "    plot.title   = element_text(size = 10, face = \"bold\", hjust = 0.5)\n",
        "  )\n",
        "\n",
        "# ── 6. CARTE DE BASE POUR LE FOND ────────────────────────────────────────────\n",
        "\n",
        "cote_ivoire <- ne_countries(country = \"Ivory Coast\", scale = \"large\", returnclass = \"sf\")\n",
        "voisins     <- ne_countries(\n",
        "  country = c(\"Ghana\", \"Liberia\", \"Guinea\", \"Mali\", \"Burkina Faso\"),\n",
        "  scale   = \"medium\", returnclass = \"sf\"\n",
        ")\n",
        "\n",
        "# Fusionner les données de volumes avec les coordonnées\n",
        "sites_vol <- left_join(coords, volumes, by = \"site\")\n",
        "sites_vol_sf <- st_as_sf(sites_vol, coords = c(\"longitude\", \"latitude\"), crs = 4326)\n",
        "\n",
        "carte_thematique <- ggplot() +\n",
        "  geom_sf(data = voisins,\n",
        "          fill = \"#F0EDE5\", color = \"#C0C0C0\", linewidth = 0.3) +\n",
        "  geom_sf(data = cote_ivoire,\n",
        "          fill = \"#ECF5E3\", color = \"#3D7A3D\", linewidth = 0.7) +\n",
        "\n",
        "  # Zone d'étude\n",
        "  annotate(\"rect\",\n",
        "           xmin = -7.5, xmax = -5.8,\n",
        "           ymin = 6.3, ymax = 7.7,\n",
        "           fill = \"#FFFBEA\", color = \"#C0392B\",\n",
        "           linewidth = 1.0, alpha = 0.6) +\n",
        "\n",
        "  # Cercles proportionnels au volume total de déchets\n",
        "  geom_point(data = sites_vol,\n",
        "             aes(x = longitude, y = latitude,\n",
        "                 size  = total_t_j,\n",
        "                 color = site),\n",
        "             shape  = 21,\n",
        "             fill   = \"white\",\n",
        "             stroke = 2.5,\n",
        "             alpha  = 0.85) +\n",
        "  geom_point(data = sites_vol,\n",
        "             aes(x = longitude, y = latitude,\n",
        "                 size  = total_t_j / 3,\n",
        "                 color = site),\n",
        "             alpha = 0.6) +\n",
        "\n",
        "  # Étiquettes volume\n",
        "  geom_label_repel(\n",
        "    data = sites_vol,\n",
        "    aes(x = longitude, y = latitude,\n",
        "        label = paste0(site, \"\\n\", total_t_j, \" t/j\"),\n",
        "        color = site),\n",
        "    size = 3.5, fontface = \"bold\",\n",
        "    fill = \"white\", alpha = 0.92,\n",
        "    label.size = 0.3,\n",
        "    box.padding = 0.6,\n",
        "    show.legend = FALSE\n",
        "  ) +\n",
        "\n",
        "  scale_color_manual(name = \"Site d'étude\", values = pal_sites) +\n",
        "  scale_size_continuous(\n",
        "    name  = \"Volume\\nde déchets\\n(tonnes/j)\",\n",
        "    range = c(5, 18),\n",
        "    breaks = c(1, 17, 50, 126)\n",
        "  ) +\n",
        "\n",
        "  annotation_scale(location = \"br\", width_hint = 0.25) +\n",
        "  annotation_north_arrow(location = \"tr\", which_north = \"true\",\n",
        "                         height = unit(1.0, \"cm\"), width = unit(1.0, \"cm\")) +\n",
        "\n",
        "  scale_x_continuous(breaks = seq(-8.5, -5, 1),\n",
        "                     labels = function(x) paste0(abs(x), \"°O\")) +\n",
        "  scale_y_continuous(breaks = seq(5, 9, 1),\n",
        "                     labels = function(y) paste0(y, \"°N\")) +\n",
        "\n",
        "  coord_sf(xlim = c(-8.0, -5.5), ylim = c(5.8, 8.2), expand = FALSE) +\n",
        "\n",
        "  theme_bw(base_size = 11) +\n",
        "  theme(\n",
        "    panel.background = element_rect(fill = \"#D6EBF5\"),\n",
        "    panel.grid.major = element_line(color = \"#CCDDEE\", linewidth = 0.3,\n",
        "                                    linetype = \"dotted\"),\n",
        "    legend.position  = \"left\",\n",
        "    legend.background = element_rect(fill = alpha(\"white\", 0.9),\n",
        "                                     color = \"#AAAAAA\"),\n",
        "    axis.title = element_blank(),\n",
        "    plot.title = element_text(size = 11, face = \"bold\", hjust = 0.5)\n",
        "  ) +\n",
        "  labs(title = \"Volume de déchets organiques\\nménagers générés par site\")\n",
        "\n",
        "# ── 7. ASSEMBLAGE FINAL ───────────────────────────────────────────────────────\n",
        "\n",
        "# Camemberts côte à côte\n",
        "pies_row <- plot_grid(pie_daloa, pie_zoukougbeu, pie_gonante,\n",
        "                      ncol   = 3,\n",
        "                      labels = NULL)\n",
        "\n",
        "pies_avec_legende <- plot_grid(\n",
        "  pies_row,\n",
        "  legende_extraite,\n",
        "  ncol       = 2,\n",
        "  rel_widths = c(3, 0.8)\n",
        ")\n",
        "\n",
        "# Rangée du haut : carte + camemberts\n",
        "rangee_haut <- plot_grid(\n",
        "  carte_thematique,\n",
        "  pies_avec_legende,\n",
        "  ncol       = 2,\n",
        "  rel_widths = c(1.2, 1),\n",
        "  labels     = c(\"A\", \"B\"),\n",
        "  label_size = 12,\n",
        "  label_fontface = \"bold\"\n",
        ")\n",
        "\n",
        "# Rangée du bas : barres volumes + barres physicochimie\n",
        "rangee_bas <- plot_grid(\n",
        "  bar_volumes,\n",
        "  bar_physico,\n",
        "  ncol       = 2,\n",
        "  rel_widths = c(0.6, 1.4),\n",
        "  labels     = c(\"C\", \"D\"),\n",
        "  label_size = 12,\n",
        "  label_fontface = \"bold\"\n",
        ")\n",
        "\n",
        "# Titre global\n",
        "titre_global <- ggdraw() +\n",
        "  draw_label(\n",
        "    \"Caractérisation des sites de collecte des déchets organiques ménagers — Haut Sassandra\",\n",
        "    fontface = \"bold\",\n",
        "    size     = 13,\n",
        "    x        = 0.5,\n",
        "    hjust    = 0.5\n",
        "  )\n",
        "\n",
        "planche_finale <- plot_grid(\n",
